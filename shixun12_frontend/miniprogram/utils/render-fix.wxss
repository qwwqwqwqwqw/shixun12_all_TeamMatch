/**
 * 小程序渲染稳定性补丁（Class 版本）
 *
 * 在任意页面 WXSS 顶部加入：
 *   @import '../../utils/render-fix.wxss';
 *
 * 然后给 page 外层的 <view> 加 class="page-safe"
 * 给 <scroll-view> 加 class="sv-safe"
 *
 * 三项修复：
 *   1. GPU 合成层隔离 → 动态内容不触发父级全量重绘
 *   2. 显式背景色继承 → 重排间隙不会透白
 *   3. 禁止横向溢出 → 避免宽度抖动引发页面级回流
 */

/* ===== 页面级容器 ===== */
.page-safe {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 100vw;
  min-height: 100vh;
  background: #F9F9FF;
  box-sizing: border-box;
}

.page-safe {
  overflow-x: hidden;
}

/* ===== GPU 独立的滚动区 ===== */
.sv-safe {
  flex: 1;
  width: 100%;
  background: inherit;
  transform: translateZ(0);
  box-sizing: border-box;
}

/* ===== 禁止 overflow:hidden 在白底动态卡片上（防闪烁） ===== */
.no-flash {
  overflow: visible !important;
}
