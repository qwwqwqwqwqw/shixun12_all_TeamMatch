<!--pages/profile-auth/profile-auth.wxml-->
<view class="page">
  <!-- 固定头部区 -->
  <view class="page-sticky">
    <view class="hd">
      <text class="hd-sub">TeamMatch · 个人资料</text>
      <text class="hd-title">完善个人信息</text>
      <text class="hd-desc">授权获取微信头像和昵称，展示在个人中心</text>
    </view>
  </view>

  <!-- 内容区 -->
  <scroll-view class="sv" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="card">
      <!-- 头像选择 -->
      <view class="form-item">
        <text class="form-label">头像</text>
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image class="avatar-img" src="{{avatarUrl || '/assets/CodeBuddyAssets/114_182/2.svg'}}" mode="aspectFill" />
          <text class="avatar-tip">点击选择头像</text>
        </button>
      </view>

      <!-- 昵称输入 -->
      <view class="form-item form-item-last">
        <text class="form-label">昵称</text>
        <input class="form-input" type="nickname" maxlength="20" placeholder="请输入或点击选择微信昵称" placeholder-class="ph" value="{{nickName}}" bindinput="onInputChange"/>
      </view>
    </view>

    <!-- 确认按钮 -->
    <view class="btn-wrap">
      <button class="submit-btn" bindtap="submitProfile" disabled="{{!canSubmit}}">确认授权</button>
    </view>
  </scroll-view>
</view>
