/*
 * 风格对齐：exit-vote-detail 参考页面
 * 背景: #F9F9FF; 卡片白底 + 圆角24rpx + 阴影0 8rpx 24rpx rgba(0,0,0,0.03) + 描边#F2F3FC
 * 标题色: #191C22; 次要色: #424753; 辅助色: #727784
 * 主色蓝: #0058BB; 边框: #F2F3FC; 暖色: #FFDCC1/#6C3A00; 绿色: #006B5C
 */

page {
  width: 100%;
  min-height: 100vh;
  background: #F9F9FF;
  color: #191C22;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "Noto Sans SC", sans-serif;
}

.page {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  background: #F9F9FF;
  box-sizing: border-box;
  padding: 0 32rpx;
}

/* ========== 吸顶固定区（与参考页面一致） ========== */
.page-sticky {
  flex-shrink: 0;
  width: 100%;
  padding: 32rpx 0 0;
  box-sizing: border-box;
}

/* ========== 头部（与参考页面一致） ========== */
.hd-sub {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #727784;
  font-weight: 500;
  font-family: Plus Jakarta Sans, sans-serif;
  line-height: 48rpx;
}

.hd-title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 56rpx;
  margin-top: 32rpx;
}

.hd-desc {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #424753;
  font-weight: 400;
  line-height: 48rpx;
  margin-top: 16rpx;
}

/* ========== 加载态（与参考页面一致） ========== */
.st-wrap {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.st-txt {
  font-size: 28rpx;
  color: #999;
  line-height: 40rpx;
}

.ld-spin {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #0058BB;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ========== 可滑动区（与参考页面一致） ========== */
.sv {
  flex: 1;
  width: 100%;
  padding-bottom: 16rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

/* ========== 通用卡片（与参考页面一致） ========== */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #F2F3FC;
  box-sizing: border-box;
  margin-top: 24rpx;
  padding: 34rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  color: #191C22;
  font-weight: 700;
  line-height: 48rpx;
  margin-bottom: 20rpx;
}

/* ========== 项目头部卡片 ========== */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.project-title {
  flex: 1;
  font-size: 32rpx;
  color: #191C22;
  font-weight: 700;
  line-height: 48rpx;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 40rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-tag.recruiting {
  background: rgba(0, 107, 92, 0.10);
  color: #006B5C;
}

.status-tag.in_progress {
  background: rgba(216, 226, 255, 0.30);
  color: #0058BB;
}

.status-tag.ended {
  background: rgba(194, 198, 213, 0.30);
  color: #727784;
}

/* 元信息行 */
.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #727784;
  font-weight: 400;
  line-height: 40rpx;
}

/* ========== 项目描述 ========== */
.card-content {
  display: block;
  font-size: 28rpx;
  color: #424753;
  font-weight: 400;
  line-height: 44rpx;
}

/* ========== 技能标签 ========== */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skill-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #424753;
  font-weight: 400;
  line-height: 36rpx;
  padding: 4rpx 16rpx;
  background: #ECEDF7;
  border-radius: 8rpx;
}

/* ========== 成员列表 ========== */
.member-list {
  display: flex;
  flex-wrap: wrap;
  gap: 32rpx;
}

.member-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ECEDF7;
  overflow: hidden;
}

.member-avatar-img {
  width: 100%;
  height: 100%;
}

.member-avatar-txt {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 88, 187, 0.10);
  color: #0058BB;
  font-size: 32rpx;
  font-weight: 700;
}

.member-name {
  font-size: 26rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 40rpx;
}

.member-role {
  font-size: 22rpx;
  color: #727784;
  font-weight: 400;
  line-height: 32rpx;
}

.member-role.leader {
  color: #0058BB;
}

/* ========== 发布者信息 ========== */
.creator-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.creator-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ECEDF7;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}

.creator-avatar-img {
  width: 100%;
  height: 100%;
}

.creator-avatar-txt {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 88, 187, 0.10);
  color: #0058BB;
  font-size: 28rpx;
  font-weight: 700;
}

.creator-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.creator-name {
  font-size: 28rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 40rpx;
}

.creator-date {
  font-size: 24rpx;
  color: #C2C6D5;
  font-weight: 400;
  line-height: 36rpx;
}

/* ========== 底部操作栏 ========== */
.bottom-bar {
  flex-shrink: 0;
  width: 100%;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  background: #F9F9FF;
  box-sizing: border-box;
}

.apply-btn {
  width: 100%;
  height: 96rpx;
  margin: 0;
  padding: 0;
  border-radius: 24rpx;
  background: #0058BB;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 96rpx;
  text-align: center;
}

.apply-btn::after {
  border: 0;
}

.apply-btn[disabled] {
  background: rgba(194, 198, 213, 0.30);
  color: #727784;
}