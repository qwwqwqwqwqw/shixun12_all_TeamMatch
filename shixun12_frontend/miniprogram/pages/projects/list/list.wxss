/*
 * 风格对齐：exit-vote-detail 参考页面
 * 背景: #F9F9FF; 卡片白底 + 圆角24rpx + 阴影0 8rpx 24rpx rgba(0,0,0,0.03) + 描边#F2F3FC
 * 标题色: #191C22; 次要色: #424753; 辅助色: #727784
 * 主色蓝: #0058BB; 边框: #F2F3FC; 暖色: #FFDCC1/#6C3A00; 绿色: #006B5C
 */

page {
  width: 100%;
  min-height: 100vh;
  background: #F9F9FF;
  color: #191C22;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "Noto Sans SC", sans-serif;
}

.page {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  background: #F9F9FF;
  box-sizing: border-box;
  padding: 0 32rpx;
}

/* ========== 吸顶固定区（与参考页面一致） ========== */
.page-sticky {
  flex-shrink: 0;
  width: 100%;
  padding: 32rpx 0 0;
  box-sizing: border-box;
}

/* ========== 头部（与参考页面一致） ========== */
.hd-sub {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #727784;
  font-weight: 500;
  font-family: Plus Jakarta Sans, sans-serif;
  line-height: 48rpx;
}

.hd-title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 56rpx;
  margin-top: 32rpx;
}

.hd-desc {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #424753;
  font-weight: 400;
  line-height: 48rpx;
  margin-top: 16rpx;
}

/* ========== 加载/空态（与参考页面一致） ========== */
.st-wrap {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.st-txt {
  font-size: 28rpx;
  color: #999;
  line-height: 40rpx;
}

.ld-spin {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #0058BB;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ========== 可滑动区（与参考页面一致） ========== */
.sv {
  flex: 1;
  width: 100%;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  box-sizing: border-box;
}

/* ========== 搜索栏（基于参考页面配色） ========== */
.search-bar {
  margin-top: 24rpx;
  margin-bottom: 0;
}

.search-input {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background: #ffffff;
  border: 2rpx solid #F2F3FC;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  opacity: 0.4;
}

.search-field {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 88rpx;
}

.ph {
  color: #C2C6D5;
}

/* ========== 项目列表 ========== */
.project-list {
  margin-top: 24rpx;
}

/* ========== 通用卡片（与参考页面一致） ========== */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #F2F3FC;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  padding: 34rpx;
}

/* ========== 卡片头部：标题 + 状态标签 ========== */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.project-title {
  flex: 1;
  font-size: 32rpx;
  color: #191C22;
  font-weight: 700;
  line-height: 48rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 状态标签（基于参考页面配色自行设计） */
.status-tag {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 40rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

/* 招募中：绿色系 */
.status-tag.recruiting {
  background: rgba(0, 107, 92, 0.10);
  color: #006B5C;
}

/* 进行中：蓝色系（对齐参考页面 trust badge） */
.status-tag.in_progress {
  background: rgba(216, 226, 255, 0.30);
  color: #0058BB;
}

/* 已结束：灰色系 */
.status-tag.ended {
  background: rgba(194, 198, 213, 0.30);
  color: #727784;
}

/* ========== 项目描述 ========== */
.card-desc {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-size: 28rpx;
  color: #727784;
  font-weight: 400;
  line-height: 40rpx;
  margin-bottom: 20rpx;
}

/* ========== 板块和人数 ========== */
.card-info {
  display: flex;
  gap: 32rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #C2C6D5;
  font-weight: 400;
  line-height: 36rpx;
}

.info-value {
  font-size: 26rpx;
  color: #424753;
  font-weight: 400;
  line-height: 36rpx;
}

/* ========== 技能标签（基于参考页面配色自行设计） ========== */
.skill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.skill-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #424753;
  font-weight: 400;
  line-height: 36rpx;
  padding: 4rpx 16rpx;
  background: #ECEDF7;
  border-radius: 8rpx;
}

/* ========== 底部信息 ========== */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 2rpx solid #F2F3FC;
}

.creator {
  font-size: 24rpx;
  color: #727784;
  font-weight: 400;
  line-height: 36rpx;
}

.deadline {
  font-size: 24rpx;
  color: #C2C6D5;
  font-weight: 400;
  font-family: Plus Jakarta Sans, sans-serif;
  line-height: 36rpx;
}

/* ========== 加载更多 ========== */
.load-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx 0 48rpx;
}