/* pages/login/login.wxss */
.welcome-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40px 30px;
  background: linear-gradient(135deg, #e8f5e9 0%, #ffffff 100%);
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50px;
}

.logo {
  width: 80px;
  height: 80px;
  margin-bottom: 20px;
}

.app-name {
  font-size: 32px;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 8px;
}

.app-desc {
  font-size: 16px;
  color: #666;
}

.features {
  width: 100%;
  max-width: 300px;
  margin-bottom: 50px;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.feature-icon {
  font-size: 20px;
  margin-right: 12px;
}

.feature-text {
  font-size: 15px;
  color: #333;
}

.enter-btn {
  width: 100%;
  max-width: 300px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  background-color: #07c160;
  color: #fff;
  font-size: 18px;
  border-radius: 25px;
}

.agreement {
  margin-top: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox {
  width: 16px;
  height: 16px;
  border: 1px solid #ccc;
  border-radius: 3px;
  margin-right: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #07c160;
  border-color: #07c160;
}

.check-icon {
  font-size: 12px;
  color: #fff;
  line-height: 1;
}

.agreement-text {
  font-size: 12px;
  color: #999;
}

.agreement-link {
  font-size: 12px;
  color: #576b95;
}

.shake {
  animation: shake 0.5s ease;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 50%, 90% { transform: translateX(-6px); }
  30%, 70% { transform: translateX(6px); }
}