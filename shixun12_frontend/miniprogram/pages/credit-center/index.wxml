<view class="page">
  <view class="hero">
    <text class="hero-title">信誉动态</text>
    <text class="hero-sub">你的信誉分与平台治理入口</text>
  </view>

  <!-- 信誉分卡片 -->
  <view class="score-card score-{{scoreLevel}}">
    <view class="score-ring">
      <text class="score-num">{{creditScore}}</text>
      <text class="score-label">当前信誉分</text>
    </view>
    <view class="score-detail" bindtap="goCreditHistory">
      <text class="score-link">查看变动记录</text>
      <text class="score-arrow">→</text>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="grid">
    <view class="grid-item" bindtap="goReport">
      <view class="grid-icon icon-red"><text>!</text></view>
      <text class="grid-title">举报</text>
      <text class="grid-desc">提交举报</text>
    </view>
    <view class="grid-item" bindtap="goAppeal">
      <view class="grid-icon icon-blue"><text>✎</text></view>
      <text class="grid-title">申诉</text>
      <text class="grid-desc">提交申诉</text>
    </view>
    <view class="grid-item" bindtap="goMyReports">
      <view class="grid-icon icon-orange"><text>☰</text></view>
      <text class="grid-title">我的举报</text>
      <text class="grid-desc">查看进度</text>
    </view>
    <view class="grid-item" bindtap="goMyAppeals">
      <view class="grid-icon icon-green"><text>✓</text></view>
      <text class="grid-title">我的申诉</text>
      <text class="grid-desc">查看进度</text>
    </view>
  </view>

  <!-- 变动记录入口 -->
  <view class="card" bindtap="goCreditHistory">
    <view class="card-left">
      <text class="card-icon">📊</text>
      <view class="card-info">
        <text class="card-title">信誉分变动记录</text>
        <text class="card-desc">查看你的信誉分变化历史</text>
      </view>
    </view>
    <text class="card-arrow">›</text>
  </view>
</view>
