.page {
  display: flex;
  flex-direction: column;
  padding: 0 32rpx;
  background: #F9F9FF;
  height: 100vh;
  box-sizing: border-box;
}

/* ========== 吸顶固定区 ========== */
.page-sticky {
  flex-shrink: 0;
}

/* ========== 头部 ========== */
.page-header { padding-top: 16rpx; margin-bottom: 16rpx; }
.page-header-top { display: flex; align-items: flex-start; justify-content: space-between; }
.page-header-top-left { flex: 1; }
.page-header-sub {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(66, 71, 83, 0.60);
  letter-spacing: 1.2rpx;
}
.page-header-title {
  font-size: 60rpx;
  font-weight: 800;
  color: #191C22;
  display: block;
  margin-top: 8rpx;
}
.page-header-desc {
  font-size: 26rpx;
  color: #424753;
  display: block;
  margin-top: 8rpx;
  font-weight: 400;
}

/* 返回功能选择按钮 */
.back-hub-btn {
  height: 56rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 28rpx;
  background: #ffffff;
  color: #0058BB;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 56rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}
.back-hub-btn::after { border: 0; }

/* ========== 团队名称徽章 ========== */
.team-badge {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  height: 64rpx;
  padding: 0 26rpx 0 26rpx;
  background: #F2F3FC;
  border-radius: 9999rpx;
  border: 2rpx solid rgba(194, 198, 213, 0.30);
  margin-bottom: 24rpx;
}

.team-badge-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #0058BB;
}

.team-badge-arrow {
  width: 16rpx;
  height: 16rpx;
  margin-left: 8rpx;
}

/* ========== 可滑动成员列表区 ========== */
.member-scroll {
  flex: 1;
  overflow-y: auto;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* ========== 成员卡片 ========== */
.member-card {
  position: relative;
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 34rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid rgba(194, 198, 213, 0.20);
  box-sizing: border-box;
}

/* 已退出成员的卡片：变灰 */
.member-card.exited {
  opacity: 0.8;
  background: rgba(242, 243, 252, 0.60);
  border-color: rgba(194, 198, 213, 0.10);
}

/* ========== 头像 ========== */
.member-avatar-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  border: 4rpx solid #ffffff;
  overflow: hidden;
  box-sizing: border-box;
}

.member-avatar-wrap.leader {
  background: rgba(0, 88, 187, 0.10);
}

.member-avatar-wrap.active {
  background: rgba(104, 250, 221, 0.30);
}

.member-avatar-wrap.exited {
  opacity: 0.5;
  background: #D8D9E3;
}

.member-avatar-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #0058BB;
}

.member-avatar-wrap.exited .member-avatar-text {
  color: #727784;
}

.member-avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  border: 4rpx solid #ffffff;
  box-sizing: border-box;
}

/* ========== 信息区 ========== */
.member-info {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.member-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #191C22;
  display: block;
}

.member-card.exited .member-name {
  color: #424753;
}

.member-id {
  font-size: 26rpx;
  color: #727784;

  display: block;
  margin-top: 4rpx;
}

.member-card.exited .member-id {
  color: #727784;
}

.member-major {
  font-size: 26rpx;
  color: #424753;
  display: block;
  margin-top: 4rpx;
}

.member-bio {
  font-size: 24rpx;
  color: #727784;
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 退出原因小字 */
.exit-reason {
  font-size: 22rpx;
  color: #727784;
  font-style: italic;
  margin-top: 6rpx;
  display: block;
}

/* ========== 右侧区 ========== */
.member-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

/* ========== 标签行 ========== */
.tag-row {
  display: flex;
  gap: 6rpx;
  justify-content: flex-end;
}

.tag {
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  line-height: 1.4;
}

.tag-leader {
  background: #FFC107;
}

.tag-active {
  background: #006B5C;
}

.tag-exited {
  background: #727784;
}

/* ========== 信任分盒子 ========== */
.trust-box {
  width: 100rpx;
  height: 80rpx;
  background: rgba(0, 88, 187, 0.05);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(0, 88, 187, 0.10);
}

.trust-box.exited {
  background: #E1E2EB;
  border-color: rgba(114, 119, 132, 0.10);
}

.trust-label {
  font-size: 18rpx;
  font-weight: 700;
  color: #0058BB;
  opacity: 0.60;
  line-height: 1;
}

.trust-box.exited .trust-label {
  color: #424753;
}

.trust-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #0058BB;
  line-height: 1;
  margin-top: 4rpx;
}

.trust-box.exited .trust-score {
  color: #424753;
}

/* ========== 更多操作图标 ========== */
.action-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
  opacity: 0.5;
}

/* 移除投票入口：默认只显示 ⋮，按下/激活卡片时才滑出文字 */
.remove-vote-entry {
  position: absolute;
  right: 18rpx;
  bottom: 14rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 14rpx;
  background: rgba(239, 68, 68, 0.10);
  border: 2rpx solid rgba(239, 68, 68, 0.18);
  border-radius: 999rpx;
  overflow: hidden;
  opacity: 0.45;
}

.remove-vote-entry .remove-vote-label {
  max-width: 0;
  overflow: hidden;
  white-space: nowrap;
  font-size: 22rpx;
  font-weight: 600;
  color: #DC2626;
  transition: max-width 0.25s ease, margin-left 0.25s ease, opacity 0.2s ease;
  opacity: 0;
}

.member-card--hover .remove-vote-entry {
  opacity: 1;
}

.member-card--hover .remove-vote-entry .remove-vote-label {
  max-width: 240rpx;
  margin-left: 4rpx;
  opacity: 1;
}

.remove-vote-icon {
  font-size: 28rpx;
  color: #DC2626;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 2rpx;
  flex-shrink: 0;
}

.member-action-hint {
  display: block;
  font-size: 22rpx;
  color: #DC2626;
  font-weight: 500;
  line-height: 30rpx;
  margin-top: 4rpx;
  white-space: nowrap;
}

.action-icon-btn {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(239, 68, 68, 0.08);
  border: 2rpx solid rgba(239, 68, 68, 0.15);
  border-radius: 12rpx;
}

.action-icon-text {
  font-size: 32rpx;
  color: #DC2626;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 2rpx;
}

/* ========== 空状态 ========== */
.empty-state { text-align: center; color: #999; margin-top: 60px; font-size: 14px; }

/* ========== 状态区样式 ========== */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 60px 20px;
}

.state-text {
  font-size: 14px;
  color: #999;
  margin-top: 8px;
}

.error-text {
  color: #E74C3C;
}

.retry-btn {
  margin-top: 16px;
  background-color: #0058BB;
  color: #fff;
  border: none;
  padding: 6px 24px;
  border-radius: 4px;
  font-size: 13px;
  line-height: 2;
}
.retry-btn::after { border: 0; }

/* 简易加载动画 */
.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid #E0E0E0;
  border-top: 3px solid #0058BB;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.empty-icon {
  font-size: 40px;
  opacity: 0.5;
}

/* ========== 邀请成员 ========== */
.invite-bar{flex-shrink:0;padding:16px 0 32px}
.invite-btn{width:100%;height:48px;background:#0058BB;color:#fff;border-radius:12px;font-size:16px;font-weight:600;display:flex;align-items:center;justify-content:center;margin:0;padding:0}
.invite-btn::after{border:0}
.invite-btn-disabled{background:#C2C6D5;color:#999}
.invite-hint{display:block;text-align:center;font-size:12px;color:#E65100;margin-top:8px}
