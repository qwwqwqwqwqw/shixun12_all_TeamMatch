<view class="page" wx:if="{{isAuthenticated}}">
  <scroll-view class="sv" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 头部标题 -->
    <view class="header">
      <text class="header-eyebrow">TEAMMATCH · 退出投票</text>
      <text class="header-title">发起投票</text>
      <text class="header-desc">对成员发起退出投票表决</text>
    </view>

    <!-- 目标成员信息卡片 -->
    <view class="member-card">
      <view class="member-avatar">
        <text class="member-avatar-text">{{targetNickname ? targetNickname.slice(0, 1) : '?'}}</text>
      </view>
      <view class="member-info">
        <text class="member-name">{{targetNickname}}</text>
        <view class="member-credit">
          <text class="member-credit-txt">信誉分 {{targetCreditScore}}</text>
        </view>
      </view>
    </view>

    <!-- 投票原因输入区 -->
    <view class="reason-section">
      <text class="reason-label">投票原因 <text class="required">*</text></text>
      <view class="reason-input-wrap">
        <textarea
          class="reason-textarea"
          placeholder="请说明发起投票的原因（如长期不活跃、违反项目规则等）"
          placeholder-class="reason-placeholder"
          maxlength="{{maxLength}}"
          value="{{reason}}"
          bindinput="onReasonInput"
          auto-height
        />
        <view class="char-count">
          <text class="char-count-text">{{reason.length}}/{{maxLength}}</text>
        </view>
      </view>
    </view>

    <!-- 退出性质选择 -->
    <view class="penalty-section">
      <text class="penalty-label">退出性质</text>
      <view class="penalty-options">
        <view
          class="penalty-option {{penaltyLevel === item.value ? 'selected' : ''}}"
          wx:for="{{penaltyOptions}}"
          wx:key="value"
          data-level="{{item.value}}"
          bindtap="onSelectPenalty"
        >
          <view class="penalty-option-hd">
            <view class="penalty-radio {{penaltyLevel === item.value ? 'checked' : ''}}">
              <view class="penalty-radio-dot" wx:if="{{penaltyLevel === item.value}}"></view>
            </view>
            <text class="penalty-option-label">{{item.label}}</text>
            <text class="penalty-option-score">{{item.score}}</text>
          </view>
          <text class="penalty-option-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 规则说明 -->
    <view class="rules-card">
      <text class="rules-title">投票规则</text>
      <view class="rules-list">
        <text class="rules-item">· 投票有效期为 24 小时，超时自动关闭</text>
        <text class="rules-item">· 多数赞成即通过，被投票成员将被移除项目</text>
        <text class="rules-item">· 被投票成员不能参与投票</text>
        <text class="rules-item">· 仅队长可手动关闭投票或查看结果</text>
      </view>
    </view>

    <!-- 底部间隙 -->
    <view style="height:180rpx;"></view>
  </scroll-view>

  <!-- 底部操作区 -->
  <view class="bottom-actions">
    <button
      class="btn-confirm"
      disabled="{{submitting}}"
      loading="{{submitting}}"
      bindtap="onConfirmTap"
    >{{submitting ? '处理中...' : '确认发起投票'}}</button>
  </view>

  <!-- 二次确认弹窗 -->
  <view class="modal-mask" wx:if="{{showConfirm}}" catchtouchmove="noop">
    <view class="modal">
      <text class="modal-title">确认发起投票</text>
      <text class="modal-content">
        即将对 <text class="modal-em">{{targetNickname}}</text> 发起退出投票，性质为
        <text class="modal-em">{{penaltyLevel === 'negotiated' ? '协商退出（-5分）' : '恶意退出（-10分）'}}</text>，
        投票将在24小时后自动截止。
      </text>
      <view class="modal-actions">
        <button class="modal-btn modal-btn-cancel" bindtap="onCancelConfirm">再想想</button>
        <button class="modal-btn modal-btn-confirm" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onDoSubmit">确认发起</button>
      </view>
    </view>
  </view>
</view>
