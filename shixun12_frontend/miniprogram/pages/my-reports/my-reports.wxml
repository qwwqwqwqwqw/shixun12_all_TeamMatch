<view class="list-page">
  <view class="page-sticky">
    <view class="hd">
      <text class="hd-title">我的举报</text>
    </view>
  </view>

  <scroll-view class="sv" scroll-y>
    <view class="state-wrap" wx:if="{{loading}}">
      <view class="ld-spin"></view>
      <text class="ld-text">加载中...</text>
    </view>

    <view class="state-wrap" wx:elif="{{error}}">
      <text class="err-text">{{error}}</text>
      <button class="retry-btn" bindtap="loadReports">重试</button>
    </view>

    <view class="empty-state" wx:elif="{{reports.length === 0}}">
      <text class="empty-text">暂无举报记录</text>
    </view>

    <view class="list" wx:else>
      <view class="card" wx:for="{{reports}}" wx:key="id">
        <view class="card-header">
          <text class="card-target">{{item.targetType === 'user' ? '👤' : '📁'}} {{item.targetName}}</text>
          <text class="card-status status-{{item.status}}">{{item.status === 'pending' ? '处理中' : '已处理'}}</text>
        </view>
        <text class="card-reason">原因：{{item.reason}}</text>
        <text class="card-time">{{item.createdAt}}</text>
      </view>
    </view>
  </scroll-view>
</view>
