page { background: #F9F9FF; color: #191C22; font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif; }
.list-page { display: flex; flex-direction: column; height: 100vh; padding: 0 32rpx; box-sizing: border-box; }
.page-sticky { flex-shrink: 0; padding: 32rpx 0 0; }
.hd-title { font-size: 48rpx; font-weight: 700; line-height: 60rpx; margin-bottom: 24rpx; }
.sv { flex: 1; overflow-y: auto; }
.state-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 160rpx 0; gap: 24rpx; }
.ld-spin { width: 48rpx; height: 48rpx; border: 4rpx solid #e0e0e0; border-top-color: #0058BB; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.ld-text { font-size: 26rpx; color: #999; }
.err-text { font-size: 26rpx; color: #999; text-align: center; }
.retry-btn { width: 160rpx; height: 64rpx; margin: 0; border-radius: 32rpx; background: #0058BB; color: #fff; font-size: 26rpx; line-height: 64rpx; }
.retry-btn::after { border: 0; }
.empty-state { display: flex; align-items: center; justify-content: center; padding: 160rpx 0; }
.empty-text { font-size: 28rpx; color: #999; }
.card { padding: 28rpx; margin-bottom: 20rpx; background: #fff; border-radius: 24rpx; outline: 2rpx solid #F1F5F9; outline-offset: -2rpx; }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.card-target { font-size: 32rpx; font-weight: 700; line-height: 44rpx; }
.card-status { font-size: 22rpx; font-weight: 600; padding: 4rpx 16rpx; border-radius: 9999rpx; }
.status-pending { background: #FFF3E0; color: #E65100; }
.status-resolved { background: #E8F5E9; color: #2E7D32; }
.card-reason { display: block; font-size: 28rpx; color: #424753; line-height: 40rpx; }
.card-desc { display: block; font-size: 26rpx; color: #727784; line-height: 36rpx; margin-top: 6rpx; }
.card-time { display: block; font-size: 22rpx; color: #94A3B8; margin-top: 8rpx; }
