page {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 0%, #f7f9ff 100%);
  color: #09244b;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.hub-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 56rpx 32rpx calc(36rpx + env(safe-area-inset-bottom));
}

.hero {
  display: flex;
  flex-direction: column;
}

.eyebrow {
  color: rgba(9, 36, 75, 0.52);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.title {
  margin-top: 12rpx;
  color: #000000;
  font-size: 50rpx;
  font-weight: 900;
  line-height: 68rpx;
}

.desc {
  margin-top: 8rpx;
  color: rgba(0, 0, 0, 0.58);
  font-size: 26rpx;
  line-height: 38rpx;
}

.card-list {
  margin-top: 44rpx;
}

.entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.entry-card--blue {
  background: #e7edfb;
}

.entry-card--green {
  background: #eaf1df;
}

.entry-card--orange {
  background: #f9efe6;
}

.entry-card--red {
  background: #fde8e8;
}

.entry-card--purple {
  background: #ede8fd;
}

.entry-card--cyan {
  background: #e0f2f1;
}

.entry-card--pink {
  background: #fce4ec;
}

.entry-card--indigo {
  background: #e8eaf6;
}

.entry-card--teal {
  background: #e0f2f1;
}

.entry-card--amber {
  background: #fff8e1;
}

.entry-main {
  flex: 1;
  min-width: 0;
}

.entry-title {
  display: block;
  color: #111111;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 44rpx;
}

.entry-subtitle {
  display: block;
  margin-top: 8rpx;
  color: rgba(0, 0, 0, 0.56);
  font-size: 24rpx;
  line-height: 34rpx;
}

.entry-arrow {
  margin-left: 20rpx;
  color: #2f54eb;
  font-size: 56rpx;
  font-weight: 300;
  line-height: 56rpx;
}
