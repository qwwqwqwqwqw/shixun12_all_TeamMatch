<!--pages/email-verify/email-verify.wxml-->
<view class="page">
  <!-- 固定头部区 -->
  <view class="page-sticky">
    <view class="hd">
      <text class="hd-sub">TeamMatch</text>
      <text class="hd-title">{{isVerified ? '已认证' : '绑定邮箱'}}</text>
      <text class="hd-desc">{{isVerified ? '你的邮箱已通过认证' : '完成邮箱验证后方可解锁全部功能'}}</text>
    </view>
  </view>

  <!-- 已认证状态 -->
  <block wx:if="{{isVerified && !isRebinding}}">
    <view class="card verified-card">
      <view class="verified-icon">✉️</view>
      <text class="verified-email">{{currentEmail}}</text>
      <text class="verified-status">✓ 已认证</text>
      <button class="rebind-btn" bindtap="startRebind">换绑邮箱</button>
    </view>
  </block>

  <!-- 未认证 / 换绑状态 -->
  <scroll-view wx:else class="sv" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="card">
      <text wx:if="{{isRebinding}}" class="rebind-tip">请输入新的学校邮箱</text>
      <!-- 邮箱输入 -->
      <view class="form-item">
        <text class="form-label">邮箱地址</text>
        <input class="form-input" type="text" maxlength="30" placeholder="请输入邮箱地址，如 example@bjtu.edu.cn" placeholder-class="ph" value="{{email}}" bindinput="onEmailInput"/>
      </view>

      <!-- 验证码区域 -->
      <view class="form-item form-item-last">
        <text class="form-label">验证码</text>
        <view class="code-row">
          <input class="form-input code-input" type="number" placeholder="请输入验证码" placeholder-class="ph" value="{{code}}" bindinput="onCodeInput" maxlength="6"/>
          <button class="send-code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendCode" loading="{{sendingCode}}" disabled="{{countdown > 0 || sendingCode}}">
            {{countdown > 0 ? countdown + 's' : '发送验证码'}}
          </button>
        </view>
      </view>
    </view>

    <!-- 错误信息 -->
    <view class="err" wx:if="{{errorMsg}}">
      <text class="err-txt">{{errorMsg}}</text>
    </view>

    <!-- 提交按钮 -->
    <view class="btn-wrap">
      <button class="submit-btn" bindtap="verifyCode" loading="{{verifying}}" disabled="{{verifying}}">
        {{isRebinding ? '确认换绑' : '验证邮箱'}}
      </button>
      <button wx:if="{{isRebinding}}" class="cancel-btn" bindtap="cancelRebind">取消换绑</button>
    </view>
  </scroll-view>
</view>
