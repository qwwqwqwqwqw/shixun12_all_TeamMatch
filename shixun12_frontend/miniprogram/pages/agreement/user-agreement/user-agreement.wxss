.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}
.page-sticky {
  flex-shrink: 0;
  background: #fff;
  padding: 32rpx 32rpx 24rpx;
}
.hd { display: flex; flex-direction: column; }
.hd-sub { font-size: 24rpx; color: #999; }
.hd-title { font-size: 40rpx; font-weight: 700; color: #333; margin-top: 8rpx; }
.sv {
  flex: 1;
  padding: 24rpx 0;
}
.card {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-top: 28rpx;
  margin-bottom: 12rpx;
}
.section-title:first-child { margin-top: 0; }
.section-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 8rpx;
}
.section-footer {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 32rpx;
  text-align: center;
}
.bottom-bar {
  flex-shrink: 0;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
}
.confirm-btn {
  width: 100%;
  height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
