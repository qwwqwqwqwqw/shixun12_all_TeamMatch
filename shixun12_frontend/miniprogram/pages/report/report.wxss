@import '../../utils/render-fix.wxss';

page {
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
  min-height: 100vh;
  background: #F8F9FC;
  color: #0D121C;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "Noto Sans SC", sans-serif;
}

.page {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 100vw;
  height: 100vh;
  background: #F8F9FC;
  box-sizing: border-box;
}

/* ========== 顶部导航栏 ========== */
.nav-bar {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 16rpx;
  background: #F8F9FC;
  box-sizing: border-box;
  flex-shrink: 0;
}

.nav-back {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #0D121C;
  line-height: 1;
  font-weight: 400;
}

.nav-title {
  font-size: 36rpx;
  color: #0D121C;
  font-weight: 700;
  line-height: 45rpx;
  margin-left: 8rpx;
}

/* ========== 吸顶头部区 ========== */
.page-sticky {
  flex-shrink: 0;
  width: 100%;
  max-width: 100vw;
  padding: 0 16rpx 0;
  box-sizing: border-box;
  background: #F8F9FC;
}

.hd-sub {
  display: block;
  font-size: 48rpx;
  color: #0D121C;
  font-weight: 700;
  font-family: "Plus Jakarta Sans", "PingFang SC", sans-serif;
  line-height: 60rpx;
  margin-top: 8rpx;
}

.hd-desc {
  display: block;
  font-size: 32rpx;
  color: #0D121C;
  font-weight: 400;
  line-height: 48rpx;
  margin-top: 12rpx;
  margin-bottom: 32rpx;
}

/* ========== 举报类型选择 ========== */
.type-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.type-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 24rpx;
  background: #ffffff;
  outline: 2rpx solid #C2C6D5;
  outline-offset: -2rpx;
  box-sizing: border-box;
}

.type-card.active {
  background: rgba(44, 114, 218, 0.10);
  outline: 2rpx solid #0058BB;
  outline-offset: -2rpx;
}

.type-icon {
  font-size: 36rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.type-label {
  font-size: 28rpx;
  color: #424753;
  font-weight: 500;
  line-height: 40rpx;
}

.type-card.active .type-label {
  color: #0058BB;
  font-weight: 700;
}

/* ========== 可滑动区 ========== */
.sv {
  flex: 1;
  width: 100%;
  overflow-y: auto;
  box-sizing: border-box;
  padding: 0 16rpx 32rpx;
  background: #F8F9FC;
  transform: translateZ(0);
}
.sv::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

/* ========== 区域标题 ========== */
.sec {
  margin-bottom: 32rpx;
}

.sec-label {
  display: block;
  font-size: 32rpx;
  color: #191C22;
  font-weight: 700;
  line-height: 48rpx;
  margin-bottom: 16rpx;
}

/* ========== 搜索框 ========== */
.search-box {
  display: flex;
  height: 96rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.search-icon-area {
  width: 68rpx;
  background: #E7EBF3;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-icon {
  font-size: 28rpx;
  line-height: 1;
}

.search-input-area {
  flex: 1;
  background: #E7EBF3;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  color: #0D121C;
  font-weight: 400;
  background: transparent;
}

.search-ph {
  color: #4B689B;
  font-size: 32rpx;
  font-weight: 400;
}

/* ========== 搜索结果列表 ========== */
.search-results {
  margin-top: 8rpx;
  background: #ffffff;
  border-radius: 24rpx;
  outline: 2rpx solid rgba(194, 198, 213, 0.30);
  outline-offset: -2rpx;
}

.search-item {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 2rpx solid #F1F5F9;
}
.search-item:last-child {
  border-bottom: 0;
}

.search-item-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(44, 114, 218, 0.20);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #0058BB;
  font-weight: 700;
  flex-shrink: 0;
  margin-right: 20rpx;
  overflow: hidden;
}

.search-item-info {
  flex: 1;
  min-width: 0;
}

.search-item-name {
  display: block;
  font-size: 30rpx;
  color: #191C22;
  font-weight: 700;
  line-height: 44rpx;
}

.search-item-desc {
  display: block;
  font-size: 24rpx;
  color: #727784;
  font-weight: 400;
  line-height: 36rpx;
}

/* ========== 已选对象卡片 ========== */
.target-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  margin-top: 16rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  border-radius: 24rpx;
  outline: 2rpx solid rgba(194, 198, 213, 0.30);
  outline-offset: -2rpx;
}

.target-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.target-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: rgba(44, 114, 218, 0.20);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #0058BB;
  font-weight: 700;
  flex-shrink: 0;
  overflow: hidden;
}

.target-info {
  flex: 1;
  min-width: 0;
}

.target-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.target-name {
  font-size: 32rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 48rpx;
}

.target-grade {
  height: 38rpx;
  padding: 0 16rpx;
  background: rgba(0, 88, 187, 0.10);
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.target-grade-text {
  font-size: 20rpx;
  color: #0058BB;
  font-weight: 700;
  font-family: "Plus Jakarta Sans", "PingFang SC", sans-serif;
  line-height: 1;
}

.target-desc {
  display: block;
  font-size: 32rpx;
  color: #424753;
  font-weight: 400;
  line-height: 48rpx;
  margin-top: 4rpx;
}

.target-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.target-remove-icon {
  font-size: 24rpx;
  color: #424753;
  line-height: 1;
}

/* ========== 举报原因标签 ========== */
.reason-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.reason-tag {
  padding: 16rpx 32rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  line-height: 40rpx;
  white-space: nowrap;
}

.reason-tag.off {
  background: #E7E8F1;
  color: #424753;
  font-weight: 500;
}

.reason-tag.on {
  background: #BA1A1A;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

/* ========== 详细说明输入 ========== */
.desc-box {
  padding: 34rpx;
  background: #F2F3FC;
  border-radius: 24rpx;
  outline: 2rpx solid rgba(194, 198, 213, 0.30);
  outline-offset: -2rpx;
  box-sizing: border-box;
}

.desc-input {
  width: 100%;
  min-height: 240rpx;
  font-size: 32rpx;
  color: #0D121C;
  font-weight: 400;
  line-height: 48rpx;
  background: transparent;
}

.desc-ph {
  color: #6B7280;
  font-size: 32rpx;
  font-weight: 400;
}

.desc-count {
  display: block;
  text-align: right;
  font-size: 32rpx;
  color: #C2C6D5;
  font-weight: 400;
  font-family: "Plus Jakarta Sans", "PingFang SC", sans-serif;
  line-height: 48rpx;
  margin-top: 8rpx;
}

/* ========== 证据上传 ========== */
.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  outline: 2rpx solid #C2C6D5;
  outline-offset: -2rpx;
  box-sizing: border-box;
}

.upload-icon {
  font-size: 48rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #424753;
  font-weight: 500;
  line-height: 40rpx;
}

/* 缩略图列表 */
.thumb-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.thumb-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-del {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.50);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-del-icon {
  font-size: 18rpx;
  color: #ffffff;
  line-height: 1;
}

/* ========== 底部提交按钮 ========== */
.bottom-area {
  padding: 32rpx 0 48rpx;
}

.btn-submit {
  width: 100%;
  height: 104rpx;
  margin: 0;
  padding: 0;
  border-radius: 24rpx;
  background: #BA1A1A;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 6rpx -4rpx rgba(186, 26, 26, 0.20),
              0 10rpx 15rpx -3rpx rgba(186, 26, 26, 0.20);
}
.btn-submit::after { border: 0; }

.btn-submit.disabled,
.btn-submit[disabled] {
  opacity: 0.5;
  box-shadow: none !important;
  background: #C2C6D5 !important;
}
