<view class="page">
  <view class="hero">
    <text class="hero-title">{{projectName ? projectName + ' · ' : ''}}推荐成员</text>
    <text class="hero-sub" wx:if="{{projectId}}">基于级联过滤算法的智能推荐</text>
    <text class="hero-sub" wx:else>基于你创建的项目推荐合适队友</text>
  </view>

  <view class="ended-banner" wx:if="{{isProjectEnded}}">
    <text class="ended-banner-text">⚠ 项目已结束，无法邀请新成员</text>
  </view>

  <view class="project-bar" wx:if="{{showProjectBar}}">
    <text class="project-bar-label">邀请到：</text>
    <view class="project-bar-chip {{item.id === activeProjectId ? 'chip-active' : ''}}" wx:for="{{myProjects}}" wx:key="id" bindtap="switchActiveProject" data-project-id="{{item.id}}">
      <text>{{item.name}}</text>
    </view>
  </view>

  <view class="search-bar">
    <view class="search-input">
      <input class="search-field" placeholder="搜索昵称或技能..." placeholder-class="ph" value="{{searchKeyword}}" bindinput="onSearchInput" />
    </view>
  </view>

  <view class="state-wrap" wx:if="{{loading}}">
    <text class="state-text">加载中...</text>
  </view>

  <view class="state-wrap" wx:elif="{{filteredUsers.length === 0 && !loading}}">
    <text class="state-text">暂未找到推荐成员</text>
    <text class="state-desc">技能匹配度过低或信誉分不足的用户已被过滤</text>
  </view>

  <scroll-view class="user-scroll" scroll-y enhanced show-scrollbar="{{false}}" wx:else>
    <view class="user-card" wx:for="{{filteredUsers}}" wx:key="userId">
      <view class="user-left">
        <image wx:if="{{item.avatarUrl}}" class="user-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="user-avatar">{{item.avatarText}}</view>
        <view class="user-info">
          <view class="user-name-row">
            <text class="user-name">{{item.nickname}}</text>
            <text class="user-credit">信誉{{item.creditScore || '--'}}</text>
          </view>
          <view class="diagnosis-bar" wx:if="{{item.authorityBreakdown}}">
            <text class="diag-text">技能匹配 {{item.matchScore}}%</text>
            <text class="diag-text diag-divider">|</text>
            <text class="diag-text">{{item.authorityBreakdown}}</text>
          </view>
          <text class="user-skills">技能: {{item.skills}}</text>
        </view>
      </view>
      <view class="invite-btn {{invitingId === item.userId ? 'inviting' : ''}}" bindtap="inviteUser" data-user-id="{{item.userId}}" data-nickname="{{item.nickname}}">
        <text wx:if="{{invitingId === item.userId}}">发送中</text>
        <text wx:else>邀请</text>
      </view>
    </view>
  </scroll-view>

  <view class="picker-overlay" wx:if="{{showProjectPicker}}" bindtap="closeProjectPicker">
    <view class="picker-panel" catchtap="">
      <text class="picker-title">选择要邀请加入的项目</text>
      <scroll-view class="picker-scroll" scroll-y wx:if="{{myProjects.length > 0}}">
        <view class="picker-item" wx:for="{{myProjects}}" wx:key="id" bindtap="selectProject" data-project-id="{{item.id}}">
          <text class="picker-name">{{item.name}}</text>
          <text class="picker-meta">{{item.members}}/{{item.maxMembers}}人</text>
        </view>
      </scroll-view>
      <text class="picker-empty" wx:else>暂无可用的招募中项目</text>
      <view class="picker-cancel" bindtap="closeProjectPicker">取消</view>
    </view>
  </view>
</view>
