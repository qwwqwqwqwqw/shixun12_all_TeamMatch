page{background:#F9F9FF;color:#191C22}
.page{padding:16px;display:flex;flex-direction:column;height:100vh;box-sizing:border-box}
.hero{margin-bottom:16px;flex-shrink:0}
.hero-title{display:block;font-size:18px;font-weight:700;color:#191C22}
.hero-sub{display:block;font-size:13px;color:#424753;margin-top:2px}

/* 项目已结束提示 */
.ended-banner{margin-bottom:14px;padding:12px 16px;background:#FFF3E0;border-radius:10px}
.ended-banner-text{font-size:13px;color:#E65100}

/* 项目选择栏 */
.project-bar{display:flex;align-items:center;gap:8px;margin-bottom:14px;flex-shrink:0;flex-wrap:wrap}
.project-bar-label{font-size:13px;color:#727784;flex-shrink:0}
.project-bar-chip{padding:6px 14px;border-radius:20px;font-size:13px;font-weight:500;background:#EDEEF4;color:#424753;white-space:nowrap}
.project-bar-chip.chip-active{background:#0058BB;color:#fff;font-weight:600}

.search-bar{margin-bottom:14px;flex-shrink:0}
.search-input{background:#fff;border-radius:10px;padding:10px 16px;display:flex;align-items:center;box-shadow:0 2px 6px rgba(0,0,0,0.03)}
.search-field{flex:1;font-size:15px;color:#191C22}
.ph{color:#C2C6D5}

.state-wrap{text-align:center;padding:64px 0}
.state-text{display:block;font-size:15px;color:#727784}
.state-desc{display:block;font-size:13px;color:#C2C6D5;margin-top:4px}

.user-scroll{flex:1;overflow-y:auto}
.user-card{display:flex;align-items:center;gap:12px;background:#fff;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.03);padding:16px;margin-bottom:12px}
.user-left{display:flex;align-items:center;gap:12px;flex:1;min-width:0}
.user-avatar{width:44px;height:44px;border-radius:50%;background:#D2E4FF;color:#0058BB;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;flex-shrink:0;overflow:hidden}
.user-info{flex:1;min-width:0}
.user-name-row{display:flex;align-items:center;gap:8px}
.user-name{font-size:16px;font-weight:600;color:#191C22}
.match-badge{background:rgba(0,88,187,0.10);padding:2px 8px;border-radius:6px;flex-shrink:0}
.match-text{font-size:11px;color:#0058BB;font-weight:600}
.user-credit{font-size:12px;color:#459A5C;font-weight:600;flex-shrink:0}
.diagnosis-bar{display:flex;align-items:center;gap:6px;margin-top:4px;flex-wrap:wrap}
.diag-text{font-size:11px;color:#727784}
.diag-divider{color:#E1E2EB}
.user-major{display:block;font-size:13px;color:#424753;margin-top:2px}
.user-skills{display:block;font-size:12px;color:#727784;margin-top:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

.invite-btn{flex-shrink:0;padding:8px 16px;background:#0058BB;color:#fff;border-radius:8px;font-size:14px;font-weight:600}
.invite-btn.inviting{opacity:0.6}

/* 项目选择弹窗 */
.picker-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);display:flex;align-items:flex-end;justify-content:center;z-index:999}
.picker-panel{width:100%;background:#fff;border-radius:16px 16px 0 0;padding:20px 16px 32px;box-sizing:border-box;max-height:50vh;display:flex;flex-direction:column}
.picker-title{display:block;font-size:17px;font-weight:700;color:#191C22;margin-bottom:14px;text-align:center}
.picker-scroll{flex:1;overflow-y:auto;max-height:240px}
.picker-item{padding:14px 16px;background:#F5F6FA;border-radius:10px;margin-bottom:10px;display:flex;justify-content:space-between;align-items:center}
.picker-name{font-size:15px;font-weight:600;color:#191C22}
.picker-meta{font-size:13px;color:#727784}
.picker-empty{text-align:center;padding:24px 0;font-size:14px;color:#C2C6D5}
.picker-cancel{text-align:center;padding:14px 0;margin-top:8px;font-size:15px;color:#727784;border-top:1px solid #E1E2EB}
