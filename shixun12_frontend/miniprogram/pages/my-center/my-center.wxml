<!--pages/my-center/my-center.wxml-->
<view class="page-bg">
  <!-- 加载态 -->
  <view class="loading-box" wx:if="{{loading}}">
    <view class="ld-spin"></view>
    <text class="load-txt">加载中...</text>
  </view>

  <!-- 内容区 -->
  <block wx:else>
    <scroll-view class="sv" scroll-y enhanced show-scrollbar="{{false}}">
      <!-- 用户信息卡片 -->
      <view class="user-card">
        <block wx:if="{{hasUserProfile}}">
          <view class="user-top">
            <button class="btn-avatar" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
              <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
            </button>
            <view class="user-info">
              <text class="user-nickname">{{userInfo.nickname}}</text>
            </view>
          </view>
        </block>

        <view class="user-top" wx:else>
          <button wx:if="{{userInfo.avatarUrl && userInfo.avatarUrl.length > 10}}" class="btn-avatar" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
          </button>
          <view wx:else class="user-avatar user-avatar-txt">{{userInfo.nickname ? userInfo.nickname.slice(0, 1) : '?'}}</view>
          <view class="user-info">
            <text class="user-nickname">{{userInfo.nickname}}</text>
            <button class="btn-get-profile" bindtap="goProfileAuth">授权微信信息</button>
          </view>
        </view>

        <view class="credit-badge">
          <text class="credit-label">信誉分</text>
          <text class="credit-score">{{userInfo.creditScore}}</text>
        </view>

        <!-- 后端档案数据 -->
        <view class="profile-extra" wx:if="{{userInfo.school || userInfo.email}}">
          <view class="extra-row" wx:if="{{userInfo.school}}">
            <text class="extra-icon">🏫</text>
            <text class="extra-text">{{userInfo.school}}</text>
          </view>
          <view class="extra-row">
            <text class="extra-icon">✉️</text>
            <text class="extra-text">{{userInfo.emailVerified ? '邮箱已认证 ' + userInfo.email : '邮箱未认证'}}</text>
          </view>
        </view>
      </view>

      <!-- 功能菜单 -->
      <view class="menu-list">
        <view class="menu-item" wx:for="{{menuList}}" wx:key="id" bindtap="{{item.action}}">
          <view class="menu-left">
            <text class="menu-icon">{{item.icon}}</text>
            <view class="menu-text">
              <text class="menu-title">{{item.title}}</text>
              <text class="menu-desc">{{item.desc}}</text>
            </view>
          </view>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <!-- 退出登录 -->
      <view class="logout-wrap">
        <button class="logout-btn" bindtap="doLogout">退出登录</button>
      </view>
    </scroll-view>
  </block>
</view>
