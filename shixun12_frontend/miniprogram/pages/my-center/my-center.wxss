/* pages/my-center/my-center.wxss */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 0%, #f7f9ff 100%);
  color: #09244b;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-bg {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
  padding: 0 32rpx;
}

/* ========== 加载态 ========== */
.loading-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding-bottom: 120rpx;
}

.ld-spin {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #2f54eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.load-txt {
  font-size: 28rpx;
  color: #999;
  line-height: 40rpx;
}

/* ========== 可滑动区 ========== */
.sv {
  flex: 1;
  width: 100%;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  box-sizing: border-box;
}

/* ========== 用户信息卡片 ========== */
.user-card {
  margin-top: 40rpx;
  padding: 36rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.user-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #ECEDF7;
  flex-shrink: 0;
  overflow: hidden;
}

.btn-avatar {
  width: 100rpx !important;
  height: 100rpx !important;
  min-width: 100rpx !important;
  max-width: 100rpx !important;
  border-radius: 50%;
  padding: 0 !important;
  padding-left: 0 !important;
  padding-right: 0 !important;
  margin: 0;
  margin-left: 0;
  margin-right: 0;
  background: transparent;
  flex-shrink: 0;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
  border: none;
}
.btn-avatar::after { border: 0; }

.user-avatar-txt {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 88, 187, 0.10);
  color: #0058BB;
  font-size: 38rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-nickname {
  font-size: 34rpx;
  color: #111111;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.btn-get-profile {
  display: inline-block;
  margin-top: 12rpx;
  padding: 10rpx 28rpx;
  background: #2f54eb;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 32rpx;
  line-height: 40rpx;
  text-align: center;
}

.btn-get-profile::after {
  border: 0;
}

/* 信誉分徽章 */
.credit-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #e7edfb;
  border-radius: 16rpx;
}

.credit-label {
  font-size: 26rpx;
  color: #888;
  line-height: 38rpx;
}

.credit-score {
  font-size: 36rpx;
  color: #2f54eb;
  font-weight: 900;
  line-height: 50rpx;
}

/* 后端档案信息 */
.profile-extra {
  margin-top: 20rpx;
  padding: 20rpx 0 0;
  border-top: 2rpx solid #f0f2ff;
}

.extra-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.extra-row:last-child {
  margin-bottom: 0;
}

.extra-icon {
  font-size: 28rpx;
  line-height: 40rpx;
}

.extra-text {
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
}

/* ========== 功能菜单 ========== */
.menu-list {
  margin-top: 24rpx;
  margin-bottom: 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  box-sizing: border-box;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f0f2ff;
  box-sizing: border-box;
}

.menu-item:last-child {
  border-bottom: 0;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.menu-icon {
  font-size: 40rpx;
  line-height: 56rpx;
  flex-shrink: 0;
}

.menu-text {
  flex: 1;
  min-width: 0;
}

.menu-title {
  display: block;
  font-size: 30rpx;
  color: #111111;
  font-weight: 600;
  line-height: 42rpx;
}

.menu-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 34rpx;
}

.menu-arrow {
  font-size: 48rpx;
  color: #ccc;
  font-weight: 300;
  line-height: 48rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ========== 退出登录 ========== */
.logout-wrap {
  padding: 16rpx 0 48rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  margin: 0;
  padding: 0;
  background: #ffffff;
  color: #d32f2f;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: 2rpx solid #fce4ec;
  line-height: 88rpx;
  text-align: center;
}

.logout-btn::after {
  border: 0;
}
