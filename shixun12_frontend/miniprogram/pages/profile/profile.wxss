page {
  min-height: 100vh;
  background: #f7f8fb;
  color: #101828;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.profile-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 80rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
}

.profile-card {
  padding: 56rpx 40rpx;
  border-radius: 36rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: #2f54eb;
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 128rpx;
  text-align: center;
}

.title {
  margin-top: 32rpx;
  color: #111111;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 56rpx;
}

.desc {
  margin-top: 12rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 38rpx;
  text-align: center;
}

.info-row {
  width: 100%;
  margin-top: 40rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #f4f6ff;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.label {
  color: #98a2b3;
  font-size: 26rpx;
  font-weight: 700;
}

.value {
  color: #2f54eb;
  font-size: 28rpx;
  font-weight: 900;
}
