/*
 * 风格对齐：exit-vote-detail 参考页面
 * 背景: #F9F9FF; 卡片白底 + 圆角24rpx + 阴影0 8rpx 24rpx rgba(0,0,0,0.03) + 描边#F2F3FC
 * 标题色: #191C22; 次要色: #424753; 辅助色: #727784
 * 主色蓝: #0058BB; 边框: #F2F3FC; 暖色: #FFDCC1/#6C3A00
 */

page {
  width: 100%;
  min-height: 100vh;
  background: #F9F9FF;
  color: #191C22;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "Noto Sans SC", sans-serif;
}

.page {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  background: #F9F9FF;
  box-sizing: border-box;
  padding: 0 32rpx;
}

/* ========== 吸顶固定区（与参考页面一致） ========== */
.page-sticky {
  flex-shrink: 0;
  width: 100%;
  padding: 32rpx 0 0;
  box-sizing: border-box;
}

/* ========== 头部（与参考页面一致） ========== */
.hd-sub {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #727784;
  font-weight: 500;
  font-family: Plus Jakarta Sans, sans-serif;
  line-height: 48rpx;
}

.hd-title {
  display: block;
  text-align: center;
  font-size: 40rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 56rpx;
  margin-top: 32rpx;
}

.hd-desc {
  display: block;
  text-align: center;
  font-size: 32rpx;
  color: #424753;
  font-weight: 400;
  line-height: 48rpx;
  margin-top: 16rpx;
}

/* ========== 可滑动区（与参考页面一致） ========== */
.sv {
  flex: 1;
  width: 100%;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  box-sizing: border-box;
}

/* ========== 通用卡片（与参考页面一致） ========== */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  border: 2rpx solid #F2F3FC;
  box-sizing: border-box;
  margin-top: 24rpx;
  padding: 34rpx;
}

/* 卡片内的分段标题（参考 vt-title 样式） */
.card-title {
  display: block;
  font-size: 32rpx;
  color: #191C22;
  font-weight: 700;
  line-height: 48rpx;
  margin-bottom: 32rpx;
}

/* ========== 表单字段 ========== */
.form-item {
  margin-bottom: 24rpx;
}
.form-item-last {
  margin-bottom: 0;
}

.picker-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.picker-custom {
  font-size: 28rpx;
  color: #0058BB;
  padding: 0 16rpx;
  flex-shrink: 0;
}

.label {
  display: block;
  font-size: 32rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 48rpx;
  margin-bottom: 12rpx;
}

/* 输入框（基于参考页面配色设计） */
.input {
  display: block;
  width: 100%;
  height: 96rpx;
  padding: 0 24rpx;
  background: #ffffff;
  border: 2rpx solid #F2F3FC;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 96rpx;
  box-sizing: border-box;
}

/* 多行文本域（基于参考页面配色设计） */
.textarea {
  display: block;
  width: 100%;
  height: 180rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 2rpx solid #F2F3FC;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 48rpx;
  box-sizing: border-box;
}

/* placeholder 颜色对齐参考页面的辅助色 */
.ph {
  color: #C2C6D5;
}

/* ========== 错误提示（基于参考页面暖色系设计） ========== */
.err {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding: 24rpx;
  background: rgba(255, 220, 193, 0.15);
  border-radius: 16rpx;
}

.err-txt {
  font-size: 28rpx;
  color: #6C3A00;
  font-weight: 400;
  line-height: 40rpx;
  text-align: center;
}

/* ========== 按钮区 ========== */
.btn-wrap {
  padding: 32rpx 0 48rpx;
}

/* 保存按钮（对齐参考页面主按钮样式） */
.save-btn {
  width: 100%;
  height: 96rpx;
  margin: 0;
  padding: 0;
  border-radius: 24rpx;
  background: #0058BB;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn::after {
  border: 0;
}

.save-btn[disabled] {
  opacity: 0.6;
}

/* ========== 头像编辑区 ========== */
.avatar-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.edit-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: #ECEDF7;
}

.edit-avatar-img {
  width: 100%;
  height: 100%;
}

.edit-avatar-txt {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 88, 187, 0.10);
  color: #0058BB;
  font-size: 34rpx;
  font-weight: 700;
}

.avatar-actions {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.avatar-label {
  display: block;
  font-size: 26rpx;
  color: #727784;
  margin-bottom: 12rpx;
}

.btn-choose-avatar {
  width: 100%;
  height: 64rpx;
  margin: 0;
  padding: 0;
  background: rgba(0, 88, 187, 0.08);
  color: #0058BB;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 64rpx;
}
.btn-choose-avatar::after { border: 0; }