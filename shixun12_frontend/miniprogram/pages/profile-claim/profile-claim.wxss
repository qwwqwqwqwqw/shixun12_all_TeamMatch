/* pages/profile-claim/profile-claim.wxss */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 0%, #f7f9ff 100%);
  color: #09244b;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-bg {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
  padding: 0 32rpx;
}

/* ========== 加载态 ========== */
.loading-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding-bottom: 120rpx;
}

.ld-spin {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #2f54eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.load-txt {
  font-size: 28rpx;
  color: #999;
  line-height: 40rpx;
}

/* ========== 可滑动区 ========== */
.sv {
  flex: 1;
  width: 100%;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  box-sizing: border-box;
}

/* ========== Hero 区域 ========== */
.hero {
  padding: 40rpx 0 36rpx;
}

.eyebrow {
  color: rgba(9, 36, 75, 0.52);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.title {
  display: block;
  margin-top: 12rpx;
  color: #000000;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 64rpx;
}

.desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(0, 0, 0, 0.58);
  font-size: 26rpx;
  line-height: 38rpx;
}

/* ========== 步骤卡片 ========== */
.step-list {
  margin-bottom: 32rpx;
}

.step-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

/* 步骤指示器 */
.step-indicator {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e7edfb;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-num {
  font-size: 28rpx;
  color: #2f54eb;
  font-weight: 700;
  line-height: 40rpx;
}

/* 步骤信息 */
.step-info {
  flex: 1;
  min-width: 0;
}

.step-title {
  display: block;
  font-size: 30rpx;
  color: #111111;
  font-weight: 700;
  line-height: 42rpx;
}

.step-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 34rpx;
}

/* 步骤按钮 */
.step-btn {
  width: 140rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  background: #2f54eb;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 32rpx;
  line-height: 64rpx;
  text-align: center;
  flex-shrink: 0;
}

.step-btn::after {
  border: 0;
}

/* ========== 底部说明 ========== */
.footer-tip {
  padding: 16rpx 0 48rpx;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.4);
  line-height: 36rpx;
}
