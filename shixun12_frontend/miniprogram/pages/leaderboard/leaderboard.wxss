/* pages/leaderboard/leaderboard.wxss */
page {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 0%, #f7f9ff 100%);
  color: #09244b;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-bg {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
  padding: 0 32rpx;
}

/* ========== 加载态 ========== */
.loading-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding-bottom: 120rpx;
}

.ld-spin {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #2f54eb;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.load-txt {
  font-size: 28rpx;
  color: #999;
  line-height: 40rpx;
}

/* ========== 可滑动区 ========== */
.sv {
  flex: 1;
  width: 100%;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  box-sizing: border-box;
}

/* ========== Hero 区域 ========== */
.hero {
  padding: 40rpx 0 36rpx;
}

.eyebrow {
  color: rgba(9, 36, 75, 0.52);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.title {
  display: block;
  margin-top: 12rpx;
  color: #000000;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 64rpx;
}

.desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(0, 0, 0, 0.58);
  font-size: 26rpx;
  line-height: 38rpx;
}

/* ========== 我的排名卡 ========== */
.my-rank-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #e7edfb 0%, #d6e0f9 100%);
  border: 2rpx solid #2f54eb;
  border-radius: 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(47, 84, 235, 0.18);
  box-sizing: border-box;
}

.my-rank-card.my-rank-top {
  background: linear-gradient(135deg, #fff3cc 0%, #ffe48a 100%);
  border-color: #f0c040;
  box-shadow: 0 6rpx 24rpx rgba(240, 192, 64, 0.25);
}

.my-tag {
  display: inline-block;
  margin-left: 8rpx;
  padding: 0 10rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  background: #2f54eb;
  border-radius: 6rpx;
  vertical-align: middle;
}

.my-rank-empty {
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  background: rgba(47, 84, 235, 0.06);
  border: 2rpx dashed rgba(47, 84, 235, 0.25);
  border-radius: 24rpx;
  text-align: center;
}

.my-rank-empty-text {
  font-size: 26rpx;
  color: rgba(9, 36, 75, 0.60);
  line-height: 36rpx;
}

/* ========== 加载更多 ========== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0 16rpx;
}

.ld-spin-small {
  width: 28rpx;
  height: 28rpx;
  border-width: 3rpx;
}

/* ========== 榜单列表 ========== */
.board-list {
  margin-bottom: 32rpx;
}

.board-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

/* 前三名特殊样式 */
.board-item.top-1 {
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cc 100%);
  border: 2rpx solid #f0c040;
}

.board-item.top-2 {
  background: linear-gradient(135deg, #f8f9fa 0%, #e8ecf1 100%);
  border: 2rpx solid #b0bec5;
}

.board-item.top-3 {
  background: linear-gradient(135deg, #fdf2f0 0%, #fae0db 100%);
  border: 2rpx solid #d4a574;
}

/* ========== 排名列 ========== */
.rank-col {
  width: 64rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-medal {
  font-size: 44rpx;
  line-height: 56rpx;
}

.rank-num {
  font-size: 32rpx;
  color: #999;
  font-weight: 700;
  line-height: 48rpx;
}

/* ========== 信息列 ========== */
.info-col {
  flex: 1;
  min-width: 0;
}

.user-name {
  display: block;
  font-size: 30rpx;
  color: #111111;
  font-weight: 700;
  line-height: 42rpx;
}

.github-name {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #2f54eb;
  font-weight: 400;
  line-height: 32rpx;
}

/* ========== 数据列 ========== */
.data-col {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.skill-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
}

.skill-chip {
  display: inline-block;
  font-size: 20rpx;
  color: #2f54eb;
  background: #e7edfb;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  line-height: 30rpx;
}

.stat-row {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #888;
  line-height: 32rpx;
}

.stat-score {
  font-size: 24rpx;
  color: #2f54eb;
  font-weight: 700;
  line-height: 32rpx;
}

/* ========== 底部操作区 ========== */
.bottom-actions {
  padding: 8rpx 0 48rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  margin: 0;
  padding: 0;
  background: #2f54eb;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after {
  border: 0;
}

.btn-secondary {
  width: 100%;
  height: 88rpx;
  margin: 0;
  padding: 0;
  background: #e7edfb;
  color: #2f54eb;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary::after {
  border: 0;
}
