page {
  width: 100%;
  min-height: 100vh;
  background: #F9F9FF;
  color: #191C22;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "WenQuanYi Zen Hei", sans-serif;
}

.page {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  background: #F9F9FF;
  box-sizing: border-box;
  padding: 0 32rpx;
}

/* ========== 吸顶固定区 ========== */
.page-sticky {
  flex-shrink: 0;
  width: 100%;
  padding: 32rpx 0 0;
  box-sizing: border-box;
}

/* ========== 头部 ========== */
.hd-sub {
  display: block;
  font-size: 20rpx;
  color: #727784;
  font-weight: 700;
  font-family: "Plus Jakarta Sans", "PingFang SC", sans-serif;
  letter-spacing: 1rpx;
  line-height: 30rpx;
}

.hd-title {
  display: block;
  font-size: 34rpx;
  color: #191C22;
  font-weight: 700;
  line-height: 44rpx;
  margin-top: 4rpx;
}

.hd-desc {
  display: block;
  font-size: 24rpx;
  color: #424753;
  font-weight: 400;
  line-height: 36rpx;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

/* ========== 申诉类型选择 ========== */
.type-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.type-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  outline: 2rpx solid #C2C6D5;
  outline-offset: -2rpx;
  box-sizing: border-box;
}

.type-card.active {
  outline: 4rpx solid #0058BB;
  outline-offset: -4rpx;
}

.type-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.type-icon-wrap.icon-active {
  background: #D8E2FF;
}

.type-icon-wrap.icon-inactive {
  background: #E1E2EB;
}

.type-icon {
  font-size: 28rpx;
  line-height: 1;
}

.type-label {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 44rpx;
}

.type-label.label-active {
  color: #0058BB;
}

.type-label.label-inactive {
  color: #424753;
}

/* ========== 可滑动区 ========== */
.sv {
  flex: 1;
  width: 100%;
  overflow-y: auto;
  box-sizing: border-box;
  padding-bottom: 32rpx;
}
.sv::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

/* ========== 加载/错误态 ========== */
.state-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.ld-spin {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #0058BB;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.ld-text {
  font-size: 26rpx;
  color: #999;
  line-height: 36rpx;
}

.err-text {
  font-size: 26rpx;
  color: #999;
  line-height: 36rpx;
  text-align: center;
  padding: 0 40rpx;
}

.retry-btn {
  width: 160rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border-radius: 32rpx;
  background: #0058BB;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
}
.retry-btn::after { border: 0; }

/* ========== 区域标题 ========== */
.sec {
  margin-bottom: 32rpx;
}

.sec-label {
  display: block;
  font-size: 26rpx;
  color: #424753;
  font-weight: 700;
  letter-spacing: 1.3rpx;
  line-height: 36rpx;
  margin-bottom: 16rpx;
  margin-left: 8rpx;
}

/* ========== 目标列表 ========== */
.target-scroll {
  width: 100%;
  max-height: 480rpx;
  background: transparent;
}
.target-list {
  width: 100%;
}

.target-card {
  display: flex;
  align-items: flex-start;
  width: 100%;
  padding: 32rpx 32rpx;
  margin-bottom: 16rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  border-radius: 24rpx;
  outline: 2rpx solid transparent;
  outline-offset: -2rpx;
  box-sizing: border-box;
}

.target-card.selected {
  outline: 4rpx solid rgba(0, 88, 187, 0.20);
  outline-offset: -4rpx;
}

.target-left {
  display: flex;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.target-thumb {
  width: 92rpx;
  height: 92rpx;
  background: #E7E8F1;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.target-info {
  flex: 1;
  min-width: 0;
}

.target-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.target-name {
  font-size: 34rpx;
  color: #191C22;
  font-weight: 700;
  line-height: 44rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.target-score {
  height: 40rpx;
  padding: 0 16rpx;
  background: #E7E8F1;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.target-score-icon {
  font-size: 18rpx;
  color: #0058BB;
  line-height: 1;
}

.target-score-val {
  font-size: 28rpx;
  color: #0058BB;
  font-weight: 700;
  font-family: "Plus Jakarta Sans", "PingFang SC", sans-serif;
  line-height: 1;
}

.target-time {
  display: block;
  font-size: 26rpx;
  color: #424753;
  font-weight: 400;
  font-family: "Plus Jakarta Sans", "PingFang SC", sans-serif;
  line-height: 36rpx;
  margin-top: 8rpx;
}

.target-reason {
  display: block;
  font-size: 26rpx;
  color: #424753;
  font-weight: 400;
  line-height: 36rpx;
  margin-top: 8rpx;
}

.target-value {
  font-size: 28rpx;
  color: #BA1A1A;
  font-weight: 700;
  font-family: "Plus Jakarta Sans", "PingFang SC", sans-serif;
  line-height: 44rpx;
  flex-shrink: 0;
}

.target-desc {
  display: block;
  font-size: 24rpx;
  color: #727784;
  line-height: 34rpx;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.target-meta {
  display: block;
  font-size: 22rpx;
  color: #0058BB;
  line-height: 30rpx;
  margin-top: 4rpx;
}
.target-check {
  width: 40rpx;
  height: 40rpx;
  background: #0058BB;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
  flex-shrink: 0;
  align-self: center;
}
.target-empty {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #C2C6D5;
}
.target-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.target-tag {
  padding: 6rpx 16rpx;
  background: rgba(255, 218, 214, 0.20);
  border-radius: 9999rpx;
  font-size: 22rpx;
  color: #BA1A1A;
  font-weight: 600;
  line-height: 32rpx;
}

/* ========== 申诉理由 ========== */
.reason-box {
  padding: 34rpx;
  background: #ffffff;
  border-radius: 24rpx;
  outline: 2rpx solid #C2C6D5;
  outline-offset: -2rpx;
  box-sizing: border-box;
}

.reason-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #191C22;
  font-weight: 400;
  line-height: 48rpx;
  background: transparent;
}

.reason-ph {
  color: #C2C6D5;
  font-size: 30rpx;
  font-weight: 400;
}

.reason-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #C2C6D5;
  font-weight: 600;
  font-family: "Plus Jakarta Sans", "PingFang SC", sans-serif;
  line-height: 30rpx;
  margin-top: 8rpx;
}

/* ========== 证据上传 ========== */
.upload-row {
  display: flex;
  gap: 16rpx;
}

.upload-box {
  flex: 1;
  aspect-ratio: 1;
}

.upload-area {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  overflow: hidden;
}

.upload-area.empty {
  background: #ffffff;
  outline: 2rpx solid #C2C6D5;
  outline-offset: -2rpx;
}

.upload-area.filled {
  position: relative;
}

.upload-img {
  width: 100%;
  height: 100%;
}

.upload-add-icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 20rpx;
  color: #727784;
  font-weight: 400;
  line-height: 28rpx;
}

.upload-del {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.50);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-del-icon {
  font-size: 18rpx;
  color: #ffffff;
  line-height: 1;
}

.upload-note {
  display: block;
  font-size: 22rpx;
  color: #727784;
  font-weight: 400;
  line-height: 36rpx;
  margin-top: 12rpx;
  margin-left: 8rpx;
}

/* ========== 底部提交按钮 ========== */
.bottom-area {
  padding: 24rpx 0 48rpx;
}

.btn-submit {
  width: 100%;
  height: 112rpx;
  margin: 0;
  padding: 0;
  border-radius: 24rpx;
  background: #0058BB;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(0, 88, 187, 0.25);
}
.btn-submit::after { border: 0; }

.btn-submit.disabled,
.btn-submit[disabled] {
  opacity: 0.5;
  box-shadow: none !important;
  background: #C2C6D5 !important;
}
